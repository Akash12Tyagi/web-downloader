PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Paths to media processing binaries (must be on PATH or absolute)
YT_DLP_PATH=yt-dlp
FFMPEG_PATH=ffmpeg

# Storage / queue tuning
TMP_DIR=./tmp
MAX_CONCURRENT_DOWNLOADS=3
JOB_TTL_MS=1800000
FILE_TTL_MS=900000
ANALYZE_CACHE_TTL_MS=300000
HISTORY_LIMIT=20

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_ANALYZE_MAX=15
RATE_LIMIT_DOWNLOAD_MAX=10
RATE_LIMIT_GENERAL_MAX=120
